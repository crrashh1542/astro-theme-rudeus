---
import BaseLayout from './BaseLayout.astro'

import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import CardBlogger from '@/components/CardBlogger.astro'
import CardNav from '@/components/CardNav.astro'
import CardTags from '@/components/CardTags.astro'

interface Props {
    title: string
    description: string
}

const { title, description } = Astro.props
---

<BaseLayout title={title} description={description}>
    <Header transition:persist />
    <main class="r-container">
        <!-- banner -->
        <div class="r-banner" transition:persist>
            <p class="r-title">Rudeus 主题文档</p>
            <p class="r-subtitle">Reference text here</p>
        </div>

        <div class="r-main-wrapper">
            <!-- 左侧功能栏 -->
            <div class="r-sidebar">
                <CardBlogger transition:persist />
                <CardNav transition:name="main" />
                <CardTags transition:persist />
            </div>

            <!-- 右侧内容区 -->
            <div class="r-content-wrapper" transition:name="main">
                <slot />
            </div>
        </div>
    </main>
    <Footer transition:persist />
</BaseLayout>

<script>
    import '@/utils/displayInfo'
    import '@/utils/runInlineScript'
    import '@/utils/copyCode'
</script>

<style lang="less">
    @import url('@/styles/variableConst.less');
    main {
        flex: 1;
    }

    .r-banner {
        text-align: center;
        padding: var(--banner-padding);
        margin-bottom: 1rem;

        .r-title {
            font-size: var(--banner-title-font);
            font-weight: 600;
            margin: var(--banner-title-margin);
            background: linear-gradient(135deg, @color-theme, @color-hover);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .r-subtitle {
            font-size: 20px;
            margin: var(--banner-subtitle-margin);
            color: @color-secondary;
        }
    }

    .r-sidebar {
        width: var(--layout-sidebar-width);
        display: flex;
        flex-direction: column;
        gap: @layout-content-spacing;
        position: sticky;
        top: (64px + @layout-content-spacing);
        align-self: flex-start;
    }

    .r-main-wrapper {
        display: flex;
        flex-direction: var(--layout-content-flex);
        gap: @layout-content-spacing;
        margin: var(--layout-main-margin);

        .r-content-wrapper {
            // display: flex;
            flex: 1;
        }
    }
</style>
