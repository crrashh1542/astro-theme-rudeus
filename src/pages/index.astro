---
import { getCollection } from 'astro:content'
import { analyzeReading } from '@/utils/readingStat'
import { genDescription } from '@/utils/genDescription'
import {
    getHomePageItems,
    getHomePageNavItems,
    getHomeTotalPages
} from '@/utils/homePagination'

import MainLayout from '@/layouts/MainLayout.astro'
import CardArticle from '@/components/CardArticle.astro'
import HomePageNav from '@/components/HomePageNav.astro'

import { siteConfig } from '@/config'

const posts = (await getCollection('archives')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)
const totalPages = getHomeTotalPages(posts.length)
const pagePosts = getHomePageItems(posts, 1)
const navItems = getHomePageNavItems(1, totalPages)
---

<MainLayout title={'首页 - ' + siteConfig.title} description={siteConfig.description}>
    <div class="r-content r-index-content">
        {
            pagePosts.map((post) => {
                const stats = analyzeReading(post.body)
                const description = post.data.description?.trim() ?? genDescription(post.body)
                return (
                    <CardArticle
                        title={post.data.title}
                        description={description}
                        pubDate={post.data.pubDate}
                        url={`/archives/${post.id}.html`}
                        category={post.data.category}
                        tags={post.data.tags}
                        readingTime={stats.minutes}
                        readingChars={stats.estimatedChars}
                        image={post.data.image}
                        data-index
                    />
                )
            })
        }

        <HomePageNav items={navItems} />
    </div>
</MainLayout>

<style>
    .r-content {
        padding: 0;
    }
</style>