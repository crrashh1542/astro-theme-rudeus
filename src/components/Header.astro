---
import { Icon } from 'astro-icon/components'
import SearchBox from '@/components/SearchBox.astro'

import { siteConfig, navConfig } from '@/config'
---

<header>
    <div class="r-container">
        <!-- 左半部分 网站目录 -->
        <div class="r-menu">
            <a href="/" class="r-index">{siteConfig.title}</a>
            <span class="r-not-mob"></span>
            {navConfig.map(i => (
                <a class="r-not-mob" href={i.url}>{i.name}</a>
            ))}
        </div>
        <!-- 右半部分 功能按钮 -->
        <div class="r-function">
            <SearchBox />
            <span class="r-dropdown r-not-pc" data-open="false">
                <span class="r-btn" id="header-dropdown-btn">
                    <Icon name="mdi:menu" width={24} height={24} />
                </span>
                <div class="r-dropdown-panel">
                    {navConfig.map(i => (
                        <a href={i.url}>{i.name}</a>
                    ))}
                </div>
            </span>
        </div>
        
    </div>
</header>

<style lang="less">
    @import url('@/styles/variableConst.less');
    header {
        background-color: rgba(255, 255, 255, .8);
        backdrop-filter: blur(5px);
        padding: var(--header-padding);
        position: sticky;
        top: 0;
        z-index: 100;

        a {
            transition: all @anim-duration ease;
        }
        a:hover {
            color: @color-theme;
        }
    }
    .r-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;

        // 左侧目录
        .r-menu {
            display: flex;
            flex-direction: row;
            font-size: 15px;
            gap: 2.5em;
            font-weight: 500;
            align-items: center;

            .r-index {
                font-size: var(--header-font);
                font-weight: 600;
            }
        }
        
        // 右侧功能按钮
        .r-function {
            display: flex;
            flex-direction: row;
            gap: 8px;
            cursor: pointer;
            
        }
        // 下拉菜单
        .r-dropdown {
            position: relative;
            display: inline-flex;
            align-items: center;

            .r-dropdown-panel {
                position: absolute;
                right: 0;
                top: calc(100% + 8px);
                min-width: 140px;
                background: rgba(255, 255, 255, .8);
                border: 1px solid #eee;
                border-radius: 10px;
                box-shadow: 0 10px 30px rgba(0, 0, 0, .08);
                padding: 8px;
                display: flex;
                flex-direction: column;
                gap: 6px;
                opacity: 0;
                transform: translateY(-6px);
                pointer-events: none;
                transition: all @anim-duration ease;
                z-index: 2;

                a {
                    padding: 6px 10px;
                    border-radius: 6px;
                    font-size: 14px;
                }
                a:hover {
                    background: @color-theme-light;
                    color: @color-theme-dark;
                }
            }
        }
        .r-dropdown[data-open='true'] {
            .r-dropdown-panel {
                opacity: 1;
                transform: translateY(0);
                pointer-events: auto;
            }
        }
    }
</style>

<script>
    let dropdownWrap: HTMLElement | null = null
    let dropdownBtn: HTMLElement | null = null

    const setDropdownOpen = (open: boolean) => {
        if (!dropdownWrap) return
        dropdownWrap.setAttribute('data-open', open ? 'true' : 'false')
    }

    const onDropdownClick = (event: Event) => {
        event.stopPropagation()
        const isOpen = dropdownWrap?.getAttribute('data-open') == 'true'
        setDropdownOpen(!isOpen)
    }

    const initHeader = () => {
        dropdownWrap = document.querySelector('.r-dropdown')
        dropdownBtn = document.getElementById('header-dropdown-btn')

        if (dropdownBtn && !dropdownBtn.dataset.bound) {
            dropdownBtn.addEventListener('click', onDropdownClick)
            dropdownBtn.dataset.bound = 'true'
        }
    }

    if (!(window as any).__rDropdownDocBound) {
        document.addEventListener('click', (event) => {
            const target = event.target as Node
            if (dropdownWrap && !dropdownWrap.contains(target)) setDropdownOpen(false)
        })
        ;(window as any).__rDropdownDocBound = true
    }

    // 处理跨页后搜索框打不开
    document.addEventListener('astro:page-load', initHeader)
    document.addEventListener('astro:after-swap', initHeader)
</script>
