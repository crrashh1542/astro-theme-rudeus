---
import { getCollection } from 'astro:content'

import { siteConfig } from '@/config'

const articles = await getCollection('posts')
const tagMap = new Map<string, number>()

articles.forEach((item) => {
    const tags = item.data.tags ?? []
    tags.forEach((tag) => {
        tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1)
    })
})

const tags = Array.from(tagMap.entries()).sort((a, b) => {
    const countDiff = b[1] - a[1]
    if (countDiff != 0) return countDiff
    return a[0].localeCompare(b[0], 'zh-Hans-CN')
})
---
{
    tags.length > 0 ? (
        <div class="r-card">
            <div class="r-title">标签</div>
            <div class="r-list">
                {tags.map(([tag, count]) => (
                    <a class="r-tag" href={`/posts${siteConfig.isWithExt ? '.html' : ''}?tag=${encodeURIComponent(tag)}`} title={`${tag}（${count}）`}>
                        <span class="r-name">{tag}</span>
                        <span class="r-count">{count}</span>
                    </a>
                ))}
            </div>
        </div>
    ) : (
        <div class="r-card empty">暂无标签</div>
    )
}

<style lang="less">
    @import url('@/styles/variableConst.less');

    .r-card {
        background-color: #fff;
        border-radius: @layout-content-border-radius;
        padding: (@layout-content-padding / 1.4) 12px;

        &.empty {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .r-title {
            font-size: 16px;
            font-weight: 600;
            margin: 0 0 10px 10px;
        }

        .r-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            padding: 4px 8px 8px;

            .r-tag {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                padding: 4px 8px;
                border-radius: @layout-border-radius;
                background-color: @color-theme-light;
                color: @color-theme-dark;
                font-size: var(--content-tag-font);
                white-space: nowrap;
                text-decoration: none;
                transition: all @anim-duration ease;

                &:active {
                    background-color: @color-card-active;
                    transform: scale(.9);
                }
            }

            .r-count {
                font-size: 12px;
                color: @color-secondary;
            }
        }
    }
</style>
