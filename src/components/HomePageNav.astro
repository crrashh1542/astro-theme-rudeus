---
import type { NavItem } from '@/utils/homePagination'

interface Props {
    items?: NavItem[]
}

const { items = [] } = Astro.props
---

{
    items.length > 1 && (
        <div class="r-pagination">
            {
                items.map(item => {
                    if (item.type === 'ellipsis') {
                        return <span class="r-page-ellipsis" aria-hidden="true">...</span>
                    }

                    return (
                        <a
                            class:list={['r-page-link', item.isCurrent && 'r-current']}
                            href={item.href}
                            aria-current={item.isCurrent ? 'page' : undefined}
                        >
                            {item.page}
                        </a>
                    )
                })
            }
        </div>
    )
}

<style lang="less">
    @import url('@/styles/variableConst.less');

    .r-pagination {
        display: flex;
        justify-content: center;
        gap: 12px;
        margin: 14px 0;
    }

    .r-page-link {
        display: inline-flex;
        width: 44px;
        height: 44px;
        align-items: center;
        justify-content: center;
        color: @color-theme;
        background-color: #fff;
        text-decoration: none;
        border-radius: 50%;
        transition: all @anim-duration ease;
        &:hover {
            background-color: @color-card-hover;
        }
        &:active {
            background-color: @color-card-active;
            transform: scale(0.95);
        }
    }

    .r-page-link.r-current {
        color: #fff;
        background-color: @color-theme;
    }

    .r-page-ellipsis {
        display: inline-flex;
        align-items: center;
        color: @color-secondary;
        padding: 0 4px;
    }
</style>
