{
    "name": "astro-theme-rudeus",
    "type": "module",
    "version": "0.4.3",
    "scripts": {
        "dev": "astro dev --port 20480",
        "build": "astro build",
        "build:docs": "git apply .github/patches/doc_comment.diff && eslint . --fix && astro build && git apply -R .github/patches/doc_comment.diff",
        "preview": "astro preview",
        "astro": "astro",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "p:check": "prettier --check src/",
        "p:write": "prettier --write src/",
        "prepare": "husky install"
    },
    "dependencies": {
        "@astrojs/rss": "^4.0.18",
        "@astrojs/sitemap": "^3.7.2",
        "@rollup/plugin-yaml": "^4.1.2",
        "astro": "^6.2.1",
        "astro-icon": "^1.1.5",
        "less": "^4.6.4",
        "modern-normalize": "^3.0.1",
        "sharp": "^0.34.5"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@iconify-json/mdi": "^1.2.3",
        "astro-eslint-parser": "^1.4.0",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-astro": "^1.7.0",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "remark-directive": "^4.0.0",
        "typescript-eslint": "^8.59.1",
        "unist-util-visit": "^5.1.0"
    },
    "lint-staged": {
        "**/*.{js,mjs,cjs,ts,astro}": "eslint . --fix",
        "**/*.{js,mjs,cjs,ts,less,md,json}": "prettier --write"
    }
}
